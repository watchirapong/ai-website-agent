# Copy to .env and fill in (never commit .env)

# LLM: default is local Ollama + Gemma (e.g. gemma3:4b). Run: ollama serve && ollama pull gemma3:4b
LLM_PROVIDER=ollama
OLLAMA_MODEL=gemma4:latest
# AI profile: speed | fast | balanced | quality | unrestricted (high max_tokens for Ollama)
AI_PROFILE=speed
# Uncap step wall-clock timeouts (each agent step can run up to PIPELINE_UNLIMITED_STEP_SECONDS, default 7 days)
# PIPELINE_UNLIMITED=1
# PIPELINE_UNLIMITED_STEP_SECONDS=604800
# Optional: custom Ollama URL (CrewAI adds /v1). Default is http://localhost:11434
# OLLAMA_BASE_URL=http://localhost:11434
# Optional overrides:
# LLM_TEMPERATURE=0.0
# LLM_MAX_TOKENS=256
# Timeout tuning (seconds)
# PIPELINE_STEP_TIMEOUT_SECONDS=300
# PLANNER_TIMEOUT_SECONDS=60
# DEVELOPER_TIMEOUT_SECONDS=300
# TESTER_TIMEOUT_SECONDS=300
# REVIEWER_TIMEOUT_SECONDS=120
# DEPLOYER_TIMEOUT_SECONDS=180

# Deploy: local = next start on 127.0.0.1 only (this PC). vercel = public Vercel deploy.
# DEPLOY_TARGET=local

# Port for GET /output/{project_id} local preview (next dev). Default 3040.
# API_PREVIEW_PORT=3040

# Windows: if output cleanup still hits file locks on next-swc.node, set to 1 to taskkill ALL node.exe
# before clearing output (closes every Node process on this machine). Default off.
# AGENT_WINDOWS_KILL_ALL_NODE=1

# Cloud Anthropic API (set LLM_PROVIDER=anthropic and add key)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# LLM_MODEL=claude-sonnet-4-20250514
