# Copy to .env and fill in (never commit .env)

# LLM: default is local Ollama + Gemma (e.g. gemma3:4b). Run: ollama serve && ollama pull gemma3:4b
LLM_PROVIDER=ollama
OLLAMA_MODEL=gemma4:latest
# AI profile: speed | fast | balanced | quality
AI_PROFILE=speed
# Optional: custom Ollama URL (CrewAI adds /v1). Default is http://localhost:11434
# OLLAMA_BASE_URL=http://localhost:11434
# Optional overrides:
# LLM_TEMPERATURE=0.0
# LLM_MAX_TOKENS=256
# Timeout tuning (seconds)
# PIPELINE_STEP_TIMEOUT_SECONDS=300
# PLANNER_TIMEOUT_SECONDS=60
# DEVELOPER_TIMEOUT_SECONDS=300
# TESTER_TIMEOUT_SECONDS=300
# REVIEWER_TIMEOUT_SECONDS=120
# DEPLOYER_TIMEOUT_SECONDS=180

# Cloud Anthropic API (set LLM_PROVIDER=anthropic and add key)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# LLM_MODEL=claude-sonnet-4-20250514
